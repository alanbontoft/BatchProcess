<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20" Width="200" Background="{DynamicResource PrimaryBackgroundGradient}">
            <!-- Add Controls for Previewer Here -->
            <Button >
                <StackPanel Orientation="Horizontal">
                    <Label Content="&#xE2C2;" Classes="icon" FontFamily="{DynamicResource PhosphorFillFont}" />
                    <Label Content="Home" />
                </StackPanel>
            </Button>
        </Border>
    </Design.PreviewWith>

    <!-- Global style for all buttons -->
    <Style Selector="Button">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}" />
        <Setter Property="Background" Value="{DynamicResource PrimaryBackground}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="FontFamily" Value="{DynamicResource AkkoProRegularFont}"></Setter>
    </Style>
    
    <!--Animate color transitions over specified time period (e.g. 0.2s)--> 
    <Style Selector="Button /template/ ContentPresenter">
        <Setter Property="Transitions" >
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.2" />
                <BrushTransition Property="Background" Duration="0:0:0.2" />
            </Transitions>
        </Setter >
    </Style>
    
    <!--Modify colors on hover over-->
    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryHoverForeground}" />
        <Setter Property="Background" Value="{DynamicResource PrimaryHoverBackground}" />
    </Style>
    
    <!--Put spacing after icon--> 
    <Style Selector="Label.icon">
        <Setter Property="FontFamily" Value="{DynamicResource PhosphorFillFont}" />
        <Setter Property="Margin" Value="0 0 5 0"></Setter>
    </Style>
    
</Styles>
