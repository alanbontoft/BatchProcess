<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="BatchProcess.Views.MacrosPageView"
             xmlns:vm="using:BatchProcess.ViewModels"
             x:DataType="vm:MacrosPageViewModel"
             Background="{DynamicResource PrimaryBackground}"
             Foreground="{DynamicResource PrimaryForeground}">

    <Design.DataContext>
        <vm:MacrosPageViewModel />    
    </Design.DataContext>

  <Label Content="{Binding PageName}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

</UserControl>
